{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== profile.md（你的記憶索引，每個 session 自動載入）===' && cat profile.md 2>/dev/null"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "atomchung": {
      "source": {
        "source": "github",
        "repo": "atomchung/claude-plugins"
      }
    }
  },
  "enabledPlugins": {
    "personal-os@atomchung": true
  }
}
